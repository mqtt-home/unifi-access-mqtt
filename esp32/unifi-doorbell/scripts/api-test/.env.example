# Copy to .env in the same directory and fill in.
# .env is git-ignored; never commit your real token.

# Hostname or IP of the UniFi Console (no scheme, no port).
UNIFI_HOST=192.168.1.1

# Developer API port. UniFi Access default is 12445.
UNIFI_PORT=12445

# Bearer API token created in UniFi Portal:
#   Access > Settings > General > Advanced > API Token > Create New
# Required scopes: view:device (list), edit:device (trigger).
UNIFI_API_TOKEN=replace-me
